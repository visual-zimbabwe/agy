{
  "name": "idea-wall",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "check:types": "tsc --noEmit",
    "check:deadcode": "tsc --noEmit --project tsconfig.deadcode.json",
    "check:styles:duplicates": "node ./scripts/check-duplicate-wall-classes.mjs",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "playwright test",
    "check:regressions": "eslint src/components/QuickCaptureBar.tsx src/components/WallCanvas.tsx --max-warnings=0 --rule \"react-hooks/set-state-in-effect:error\" --rule \"react-hooks/refs:error\"",
    "baseline:capture": "powershell -ExecutionPolicy Bypass -File ./scripts/capture-ux-baselines.ps1"
  },
  "dependencies": {
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.95.3",
    "dexie": "^4.3.0",
    "fuse.js": "^7.1.0",
    "jspdf": "^4.1.0",
    "konva": "^10.2.0",
    "lz-string": "^1.5.0",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-konva": "^19.2.2",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "jsdom": "^28.0.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.18"
  }
}
