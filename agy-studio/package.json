{
  "name": "agy-studio",
  "version": "0.1.0",
  "private": true,
  "description": "Agy desktop app powered by Electron and Next.js",
  "main": "electron/main.cjs",
  "author": "Agy Team",
  "license": "UNLICENSED",
  "scripts": {
    "dev:web": "npm --prefix .. run dev",
    "dev:electron": "wait-on tcp:3000 && electron .",
    "dev": "concurrently -k \"npm run dev:web\" \"npm run dev:electron\"",
    "build:web": "cross-env NEXT_OUTPUT=standalone npm --prefix .. run build",
    "prep:web": "node ./scripts/prepare-web.mjs",
    "pack": "npm run build:web && npm run prep:web && electron-builder --dir",
    "dist": "npm run build:web && npm run prep:web && electron-builder",
    "dist:publish": "npm run build:web && npm run prep:web && node ./scripts/publish-release.mjs",
    "smoke": "node ./scripts/smoke-check.mjs"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^32.3.0",
    "electron-builder": "^24.13.3",
    "wait-on": "^8.0.5"
  },
  "dependencies": {
    "electron-log": "^5.4.3",
    "electron-updater": "^6.6.2"
  },
  "build": {
    "appId": "com.agy.app",
    "productName": "Agy",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "electron/**/*",
      "package.json",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": ".dist/web",
        "to": "app/web",
        "filter": [
          "**/*"
        ]
      }
    ],
    "asar": true,
    "compression": "maximum",
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.productivity",
      "artifactName": "${productName}-${version}.${ext}"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Office",
      "artifactName": "${productName}-${version}.${ext}"
    }
  }
}

